# Outside bundle
bundle agent main
{
  # Inside bundle, outside promise type
  vars:
    # Inside promise type
    "some_var"
      if => "something",
      # Inside promise, next to attributes
      string => "value";

    # Before next promise
    "some_list"
      slist => {
        "Strings that go in a list which would be long",
        # Comment inside list of elements
        "More strings",
        "More and more and more and more",
      };

    # A class guard shifts everything over 2 spaces:
    class_guard::
      # Inside promise type
      "some_var"
        if => "something",
        # Inside promise, next to attributes
        string => "value";

    # A class guard shifts everything over 2 spaces:
    class_guard::
      # Inside promise type
      "some_var"
        if => "something",
        # Inside promise, next to attributes
        string => "value";
}

bundle agent check
{
  methods:
    "any"
      # Verify that the custom failsafe.cf did run and created the
      # file that we removed earlier.
      usebundle => dcs_passif_fileexists(
        "$(sys.inputdir)/failsafe_output.txt", "$(this.promise_filename)"
      );
}
