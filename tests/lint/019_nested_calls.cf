body copy_from mycopy(from)
{
  source => "$(from)";
}

bundle agent helper(arg)
{
  reports:
    "$(arg)";
}

bundle agent main
{
  files:
    "/tmp/test"
      copy_from => mycopy(readfile("/etc/source", "100"));
  methods:
    "test"
      usebundle => helper(format("hello %s", "world"));
  vars:
    "x" string => format("nested: %s", getuid("root"));
}
